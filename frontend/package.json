{
  "name": "nexus-i-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run sitemap",
    "preview": "vite preview",
    "start:prod": "node scripts/serve-dist.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
