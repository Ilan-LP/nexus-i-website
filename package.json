{
  "name": "nexus-i-website",
  "version": "1.0.0",
  "description": "Monorepo root for Nexus-I frontend and backend",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspace frontend",
    "build:prod": "npm run install:prod && npm run build --workspace frontend",
    "preview": "npm run preview --workspace frontend",
    "start": "npm run start --workspace backend",
    "install:prod": "npm ci --include=dev",
    "prune:prod": "npm prune --omit=dev",
    "pm2:start": "pm2 startOrReload ecosystem.config.js --env production --update-env",
    "pm2:stop": "pm2 delete nexus-i-frontend nexus-i-backend",
    "start:prod": "npm run build:prod && npm run prune:prod && npm run pm2:start",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ilan-LP/nexus-i-website.git"
  },
  "keywords": [
    "freelance developer",
    "website development",
    "workflow automation",
    "react",
    "vite"
  ],
  "author": "Nexus-I",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Ilan-LP/nexus-i-website/issues"
  },
  "homepage": "https://github.com/Ilan-LP/nexus-i-website#readme",
  "dependencies": {},
  "devDependencies": {
    "eslint": "^9.38.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "prettier": "^3.6.2"
  }
}
